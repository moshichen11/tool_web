MOCK_SERVER_HOST=127.0.0.1
MOCK_SERVER_PORT=8787
MOCK_SSE_INTERVAL_MS=1000
MOCK_RATE_LIMIT_WINDOW_MS=60000
MOCK_RATE_LIMIT_MAX_REQUESTS=120

# Default uses the server-side Xueqiu provider. Credentials must stay in env.
STOCK_DATA_SOURCE=xueqiu
XUEQIU_COOKIE=
XUEQIU_TOKEN=
XUEQIU_TIMEOUT_MS=6000
XUEQIU_RETRY_ATTEMPTS=3
XUEQIU_RETRY_DELAY_MS=250
XUEQIU_CACHE_TTL_MS=5000
XUEQIU_RATE_LIMIT_WINDOW_MS=60000
XUEQIU_RATE_LIMIT_MAX_REQUESTS=90

# Optional: set STOCK_DATA_SOURCE=tushare to call the licensed Tushare Pro HTTP API from the server.
TUSHARE_API_URL=http://api.tushare.pro
TUSHARE_TOKEN=
STOCK_LICENSE_REQUIRED=true
STOCK_WEB_SCRAPING_FORBIDDEN=true
