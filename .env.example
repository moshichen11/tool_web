MOCK_SERVER_HOST=127.0.0.1
MOCK_SERVER_PORT=8787
MOCK_SSE_INTERVAL_MS=1000
MOCK_RATE_LIMIT_WINDOW_MS=60000
MOCK_RATE_LIMIT_MAX_REQUESTS=120

# Local-dev/test/demo only. Production market data must use a licensed source.
STOCK_DATA_SOURCE=mock-a-share
# Set STOCK_DATA_SOURCE=tushare to call the licensed Tushare Pro HTTP API from the server.
TUSHARE_API_URL=http://api.tushare.pro
TUSHARE_TOKEN=
STOCK_LICENSE_REQUIRED=true
STOCK_WEB_SCRAPING_FORBIDDEN=true
